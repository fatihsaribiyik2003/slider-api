@model  IEnumerable<SubuProtokol.WEBUI.Models.ApiUserModel>;
@{
    ViewData["Title"] = "GetAllUser";
    Layout = "~/Views/Shared/_LayoutFull.cshtml";
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/bootstrap-select/js/bootstrap-select.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
}

<div class="container">
    <div class="row message-wrapper rounded shadow mb-20">
        <div class="col-md-12 message-sideright">
            <div class="panel">
                <div class="form-group row" style="margin-top: 10px;">
                    <div class="col-md-6">
                        <h3>Kullanıcı Listesi</h3>
                    </div>
                    <div class="col-md-6">
                        <a class="btn btn-primary" style="float:right"  asp-controller="User" asp-action="CreateUser">Ekle</a>
                    </div>
                </div>
            </div>
            <div class="panel">

                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Birim</th>
                            <th scope="col">Ad Soyad</th>
                            <th scope="col">Kullanıcı Adı</th>
                            <th scope="col">Telefon</th>
                            <th scope="col">Rol</th>
                            <th scope="col">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <th scope="row">@item.Id</th>
                            
                                <td>@item.FirstName @item.FamilyName</td>
                                <td>@item.UserName</td>
                                <td>@item.Email</td>
                                <td>@item.Phone</td>
                                <td>@item.UserRole.ToString()</td>
                                <td>
                                    <a class="btn btn-warning" asp-controller="User" asp-action="EditUser" asp-route-id="@item.Id">Düzenle</a>
                                    <button class="btn btn-danger deleteBtn" data-id="@item.Id">Sil</button>
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script>
        $('.deleteBtn').click(function () {
            if (confirm("Kaydı silmek istediğinize eminmisiniz?")) {
                $.ajax({
                    method: 'Delete',
                    url: '/User/Delete',
                    data: { id: $(this).attr('data-id') },
                    statusCode: {
                        200: function () {
                            alert("Kayıt silindi.");
                            location.replace(location.href);
                        },
                        500: function () {
                            alert("Kayıt silinemedi!");
                        }
                    }
                });
            }
        })
    </script>

   

}

