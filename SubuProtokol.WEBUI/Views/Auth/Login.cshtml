@model SubuProtokol.WEBUI.Models.ApiUserLoginModel;
@{
    
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="container h-100">
    <div class="row h-100">
        <div class="col-sm-10 col-md-8 col-lg-6 mx-auto d-table h-100">
            <div class="d-table-cell align-middle">
                <div class="card">
                    <div class="card-body">
                       <br/>
                       <br/>
                        <div class="m-sm-4">
                             
                            @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
                            {
                                <input type="hidden" asp-for="ReturnUrl">
                                <img src="~/icon/LOGO.png" width="100%" />
                                <div class="auth-login-form" method="POST">
                                    <div class="form-group mb-2">
                                        
                                    </div>
                                    </div>
                                <div class="form-group">
                                    <label asp-for="UserName">Kullanıcı Adı</label>
                                    <input class="form-control form-control-lg" asp-for="UserName" placeholder=" Kullanıcı Adınızı Giriniz">
                                    <span asp-validation-for="UserName"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="Password">Parola</label>
                                    <input class="form-control form-control-lg" type="password" asp-for="Password" placeholder="Şifrenizi Giriniz">
                                    <span asp-validation-for="Password"></span>
                                </div>
                         
                                <div class="text-center mt-3">
                                    <button type="submit" class="btn btn-lg btn-primary" style="float: right;">Giriş Yap</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <div style =" padding:11%; display: flex; justify-content: space-between;"></div>
</div>
<script>
    // TempData'dan veriyi al
    var message = '@TempData["HataliGiris"]';
    // Eğer TempData nesnesi boş değilse uyarı mesajını göster
    if (message) {
        alert(message);
    }
</script>