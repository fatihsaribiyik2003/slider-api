@using Newtonsoft.Json
﻿@using SubuProtokol.Core.Enums
@model SubuProtokol.WEBUI.Models.ProtokolQuery

@{
    ViewData["Title"] = "ProtokolCreate";
    Layout = "~/Views/Shared/_LayoutFull.cshtml";
    //ViewData["protokolekle"] = "PROTOKOL EKLE";
}



@*<div class="container">
    <div class="row message-wrapper rounded shadow mb-20">
        <div class="col-md-12 message-sideright">*@

<div class="panel">
    @using (Html.BeginForm("ProtokolCreate", "ProtokolAdmin", FormMethod.Post, new { enctype = "multipart/form-data", id = "id" }))
    {
        <input type="hidden" name="id" value="" />
        <div class="form-group row">
            <div class="col-md-6">
                <label class="font-weight-bold"><strong>Protokol İlgili Olduğu Ana Süreç</strong></label>
                <span class="text-danger"> *</span>
                <div>
                    <select asp-for="MainSurec" asp-items="Html.GetEnumSelectList<enumprotokolmainsurec>()" class="form-control" style="width: 624px; height: 39px;">
                        <option value="">Seçim yapınız</option>
                    </select>
                    <span asp-validation-for="MainSurec" class="text-danger"></span>
                </div>
            </div>
            <div class="col-sm-6">
                <label class="font-weight-bold"><strong>Protokol Ana Türü</strong></label>
                <span class="text-danger"> *</span>
                <div>
                    <select asp-for="MainType" asp-items="Html.GetEnumSelectList<EnumProtokolMainType>()" class="form-control" style="width: 624px; height: 39px;">
                        <option value="">Seçim yapınız</option>
                    </select>
                    <span asp-validation-for="MainType" class="text-danger"></span>
                </div>
            </div>
        </div>
        <br />
        <div class="form-group row">
            <div class="col-sm-6">
                <label asp-for="ProtokoldenSorumluKisi" class="font-weight-bold"><strong>Protokolden Sorumlu Kişi</strong></label><span class="text-danger"> *</span>
                <span class="text-danger"> </span>
                <input asp-for="ProtokoldenSorumluKisi" class="form-control">
                <span asp-validation-for="ProtokoldenSorumluKisi"></span>
            </div>
            <div class="col-sm-6">
                <label for="UnitId" class="font-weight-bold"><strong>Protokolden Sorumlu Birim</strong></label><span class="text-danger"> *</span>
                <select id="UnitId" name="UnitId" class="form-control">
                    <option>Seçim Yapınız</option>
                </select>
            </div>
        </div>
        <br />
        <div class="form-group row">
            <div class="col-md-6">
                <label asp-for="ProtokolImzalananKurum" class="form-label col-form-label"><strong>Protokol İmzalanan Kurum</strong></label><span class="text-danger"> *</span>
                <input asp-for="ProtokolImzalananKurum" id="btn-number" class="form-control" />
                <span asp-validation-for="ProtokolImzalananKurum" class="text-danger"></span>
            </div>
            <div class="col-sm-6">
                <label class="form-label col-form-label"> <strong>Protokol Alt Türü</strong></label><span class="text-danger">*</span>
                @Html.DropDownListFor(Model => Model.UnderType, Enum.GetValues(typeof(EnumProtokolUnderType)).Cast<EnumProtokolUnderType>().Select(x => new SelectListItem { Value = ((int)(EnumProtokolUnderType)x).ToString(), Text = x.GetDisplayNameUnderType() }), "Seçim yapınız",new{style="width:624px;height:39px;"})
            </div>
        </div>
        <br />
        <div class="form-group row">
            <div class="col-sm-6">
                <label asp-for="Scope" class="form-label col-form-label">
                    <strong>Protokol Kapsamı</strong>
                </label><span class="text-danger"> *</span>
                <select asp-for="Scope"
                    class="form-control"
                    asp-items="Html.GetEnumSelectList<EnumProtokolScope>()">
                    <option>Seçim Yapınız</option>
                </select>
            </div>
            <div class="col-sm-6">
                <label asp-for="Sector" class="form-label col-form-label"><strong>Sektör</strong></label><span class="text-danger"> *</span>
                <select asp-for="Sector"
                    asp-items="@(new SelectList(Enum.GetValues(typeof(EnumSector))))"
                    class="form-control">
                    <option>Seçim Yapınız</option>
                </select>
                <span asp-validation-for="Sector"></span>
            </div>
        </div>
        <br />
        <div class="form-group row">
            <div class="col-sm-6">
                <label asp-for="Time" class="form-label col-form-label">
                    <strong>Protokol Süresi Otomatik Uzayacak Mı?</strong>
                </label><span class="text-danger"> *</span>
                <select asp-for="Time" class="form-control" asp-items="Html.GetEnumSelectList<EnumProtokolTime>()">
                    <option>Seçim Yapınız</option>
                </select>
                <span asp-validation-for="Time"></span>
            </div>

            <div class="col-sm-6">
                <label asp-for="Email" class="form-label col-form-label">
                    <strong>Email/Web</strong>
                </label><span class="text-danger"> *</span>
                <input asp-for="Email" type="text" id="btn-email" class="form-control">
                <span asp-validation-for="Email"></span>
            </div>
        </div>
        <br />
        <div class="form-group row">
            <div class="col-sm-6">
                <label id="tarih1" asp-for="ProtokolStartTime" class="form-label col-form-label"><strong>Protokol İmza Tarihi</strong></label>
                <span class="text-danger">*</span>
                <input asp-for="ProtokolStartTime" type="date" class="form-control">
                <span asp-validation-for="ProtokolStartTime"></span>
            </div>
            <div class="col-sm-6">
                <label asp-for="ProtokolFinishTime" class="form-label col-form-label"><strong>Protokol Bitiş Tarihi</strong></label>  <span class="text-danger">*</span>
                <span class="text-danger">*</span>
                <input asp-for="ProtokolFinishTime" type="date" class="form-control">
                <span asp-validation-for="ProtokolFinishTime"></span>
            </div>
        </div>
        <br />
        <div class="form-group row">
            <div class="col-sm-6">
                <div class="panel" id="indirim">
                    <label asp-for="indirimAciklamasi"><strong>Açıklama</strong></label>  <span class="text-danger">*</span>
                    <span class="text-danger"></span>
                    <input asp-for="indirimAciklamasi" class="form-control">
                    <span asp-validation-for="indirimAciklamasi"></span>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="col-md-6">
                    <label asp-for="Telefon" class="font-weight-bold"><strong>Telefon</strong></label><span class="text-danger"> *</span>
                    <input asp-for="Telefon" id="btn-number" class="form-control" />
                    <span asp-validation-for="Telefon" class="text-danger"></span>
                </div>

            </div>
        </div>
        <br />
        <div class="form-group row">
            <div class="col-sm-6">
                <label asp-for="Konu"><strong>Konu</strong></label>  <span class="text-danger">*</span>
                <span class="text-danger"></span>
                <input asp-for="Konu" class="form-control">
                <span asp-validation-for="Konu"></span>
            </div>
            <div class="col-sm-6">
                <label asp-for="EmailImzalananKurum" class="form-label col-form-label">
                    <strong>Protokol İmzalanan Kurum Email</strong>
                </label><span class="text-danger"> *</span>
                <input asp-for="EmailImzalananKurum" type="text" id="btn-email" class="form-control">
                <span asp-validation-for="EmailImzalananKurum"></span>
            </div>
        </div>

        <div class="form-group row">
            <div class="col-sm-6">
                <label><strong>Lütfen taranmış protokol dosyasını ekleyiniz (.pdf)</strong></label>  <span class="text-danger">*</span>
                <input asp-for="File" class="form-control-file" accept="application/pdf" />
                <span asp-validation-for="File"></span>
            </div>
            <div class="col-sm-6">
                <br>
                <button type="submit" id="btn-kaydet" class="btn btn-primary" style="float: right;"><strong>Kaydet</strong></button>
            </div>
        </div>
    }
</div>

@section Styles{
    <link href="~/lib/quill/quill.snow.css" rel="stylesheet">
    <link href="~/lib/font-awesome/css/font-awesome.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.6.4/css/bootstrap-datepicker.css" type="text/css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.6.4/js/bootstrap-datepicker.js" type="text/javascript"></script>


    <link href="~/css/ticket-get.css" rel="stylesheet" />
}

